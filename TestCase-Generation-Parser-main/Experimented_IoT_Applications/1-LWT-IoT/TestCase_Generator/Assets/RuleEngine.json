[
  {
    "rule": {
      "ruleName": "SensorDataToLambda",
      "sql": "SELECT sensorId, timestamp, temperature, pressure FROM \"sensor/data\"",
      "actions": [
        {
          "lambda": {
            "functionArn": "arn:aws:lambda:ap-south-1:123456789012:function:lambda-data-status-handler"
          }
        }
      ]
    }
  },
  {
    "rule": {
      "ruleName": "SensorStatusToLambda",
      "sql": "SELECT sensorId, status, timestamp FROM \"sensor/status\"",
      "actions": [
        {
          "lambda": {
            "functionArn": "arn:aws:lambda:ap-south-1:123456789012:function:lambda-data-status-handler"
          }
        }
      ]
    }
  },
  {
    "rule": {
      "ruleName": "SensorStatusToAlarmLambda",
      "sql": "SELECT sensorId, status, timestamp FROM \"sensor/status\"",
      "actions": [
        {
          "lambda": {
            "functionArn": "arn:aws:lambda:ap-south-1:123456789012:function:lambda-alarm-handler"
          }
        }
      ]
    }
  }
]
